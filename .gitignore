# OS
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
*.swp

# Credentials — never commit these
.env
secrets/
credentials/

# Account folders — local only
# CRM data stays in your CRM. Account folders are for qualitative notes
# that don't belong in your CRM (political context, relationship nuance, etc.)
# _template/ and README.md are committed; actual account folders are not.
Accounts/[!_]*/

# Generated pipeline reports — derived from CRM data, local only
Pipeline/Weekly-Reviews/*.md
Pipeline/Forecasts/*.md

# Raw CRM exports
Pipeline/*.csv
Pipeline/*.xlsx

# Large attachments
*.pdf
*.pptx
*.docx
